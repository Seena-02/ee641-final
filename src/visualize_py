from sklearn.decomposition import PCA
import matplotlib.pyplot as plt

from vision_transformer import embedding_list, encodings


# Reduce to 2D
pca = PCA(n_components=2)
emb_2d = pca.fit_transform(embedding_list.numpy())

# Plot
plt.figure(figsize=(6,6))
plt.scatter(emb_2d[:,0], emb_2d[:,1])
for i, img_name in enumerate(encodings.keys()):
    plt.text(emb_2d[i,0]+0.01, emb_2d[i,1]+0.01, img_name, fontsize=8)
plt.title("2D PCA of ViT Embeddings")
plt.xlabel("PC1")
plt.ylabel("PC2")
plt.savefig('pca_3.png')  # Saves as a PNG image
plt.show()